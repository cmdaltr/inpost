# === Notion ===
NOTION_API_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# === LinkedIn ===
LINKEDIN_CLIENT_ID=xxxxxxxxxxxxxxxx
LINKEDIN_CLIENT_SECRET=xxxxxxxxxxxxxxxx
LINKEDIN_REDIRECT_URI=http://localhost:3456/callback

# === AI Provider (set at least one) ===
# Groq recommended - best free tier (14,400 req/day)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
# Or Gemini (free tier available)
GEMINI_API_KEY=AIza...your-key-here
# Or Anthropic (paid)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# === Optional ===
LOG_LEVEL=info
DEFAULT_TONE=professional
DEFAULT_NOTEBOOK=notion             # notion | onenote | obsidian | evernote

# === Scheduler ===
SCHEDULE_CRON=0 11 * * 1
SCHEDULE_TIMEZONE=Europe/London
SCHEDULE_LIMIT=1
PIPELINE_ORDER=oldest              # oldest | newest — which ready posts to pick first

# === Obsidian (no API key needed) ===
OBSIDIAN_VAULT_PATH=/Users/you/Documents/MyVault
OBSIDIAN_NOTES_DIR=Blog Posts           # optional — scope to a subdirectory

# === OneNote (requires Azure AD app — see docs/note-providers.md) ===
ONENOTE_CLIENT_ID=
ONENOTE_CLIENT_SECRET=
ONENOTE_TENANT_ID=consumers             # use "consumers" for personal Microsoft accounts
ONENOTE_REDIRECT_URI=http://localhost:3456/callback

# === Evernote (requires developer token — see docs/note-providers.md) ===
EVERNOTE_TOKEN=
EVERNOTE_NOTEBOOK=                      # optional — scope to a specific notebook
EVERNOTE_SANDBOX=false
